{
  "expo": {
    "name": "Memory Twin",
    "slug": "memory-twin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "memorytwin",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/images/icon.png",
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.sarjavex.memorytwin",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#05070F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#070914",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "音声入力（話した内容の文字起こし）のためにマイクを使用します。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "人物の写真を登録するためにフォトライブラリを使用します。写真はこの端末内にのみ保存されます。"
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-sharing",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "アプリロック（記録の保護）のためにFace IDを使用します。"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "693ee30f-a7b6-4a71-91e0-8de4993e666d"
      }
    },
    "owner": "sarjavex",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/693ee30f-a7b6-4a71-91e0-8de4993e666d",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 10000
    }
  }
}
