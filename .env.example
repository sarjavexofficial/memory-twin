# --- 本番の形: 自社Sarjavex AI API経由（キーがアプリに埋まらない） ---
# sarjavex-api/ を起動またはデプロイしてURLを設定する
# EXPO_PUBLIC_SARJAVEX_API_URL=http://localhost:8787
# EXPO_PUBLIC_SARJAVEX_APP_KEY=sarjavex-secret-xxxx

# --- 開発用の直接続（Sarjavex API未設定時のフォールバック） ---
# 無料: https://aistudio.google.com で取得（Googleアカウントがあれば数分・クレカ不要）
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-key-here
# 有料フォールバック（任意）
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- こだま（匿名共有掲示板）: Supabaseの無料プランで動作 ---
# https://supabase.com で無料プロジェクトを作成し、Project Settings > API から取得
# EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
